{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    // MSP opts out of noUncheckedIndexedAccess (base default is `true`).
    // Scoped here, not in tsconfig.base.json, so gks/web keep the strict guard.
    "noUncheckedIndexedAccess": false
  },
  "references": [
    { "path": "../gks" }
  ],
  "include": ["src/**/*", "test/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "gks",
    ".brain",
    "web"
  ]
}
