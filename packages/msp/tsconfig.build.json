{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    // rootDir must be `src` (not the inherited `.`) so emit lands directly in
    // dist/ — package.json `main`/`bin` point at ./dist/<x>.js, not ./dist/src/.
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "test/**/*",
    "node_modules",
    "dist",
    "gks",
    ".brain"
  ]
}
