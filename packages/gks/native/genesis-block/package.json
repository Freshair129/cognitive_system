{
  "name": "@freshair129/gks-genesis-block-native",
  "version": "0.0.1",
  "description": "Genesis Block — native Rust embedded graph engine for GKS (P3.1 scaffold)",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js",
    "package.json"
  ],
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "napi": {
    "binaryName": "genesis-block",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepare": "npm run build",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "node --test __test__"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  }
}
